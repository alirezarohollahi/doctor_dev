# Doctor Dev Panel production example
DOCTOR_DEV_PANEL_HOST=0.0.0.0
DOCTOR_DEV_PANEL_PORT=8088
DOCTOR_DEV_PANEL_PUBLIC_URL=http://YOUR_SERVER_IP:8088
DOCTOR_DEV_AUTH_REQUIRED=1
DOCTOR_DEV_ADMIN_USERNAME=admin
DOCTOR_DEV_ADMIN_PASSWORD=change-me-long-random-password
DOCTOR_DEV_APP_SECRET=change-me-long-random-session-secret
DOCTOR_DEV_SESSION_TTL_SECONDS=43200
DOCTOR_DEV_DATA_DIR=/var/lib/doctor_dev/panel
DOCTOR_DEV_LOG_DIR=/var/log/doctor_dev/panel
DOCTOR_DEV_CONFIG_DIR=/etc/doctor_dev/panel/generated
DOCTOR_DEV_CERT_DIR=/etc/doctor_dev/certs
DOCTOR_DEV_PANEL_SSL_CERTFILE=
DOCTOR_DEV_PANEL_SSL_KEYFILE=

# Doctor Dev Node production example
DOCTOR_DEV_NODE_NAME=edge-node-1
DOCTOR_DEV_NODE_PUBLIC_ADDRESS=YOUR_NODE_IP_OR_DOMAIN
DOCTOR_DEV_AGENT_HOST=0.0.0.0
DOCTOR_DEV_AGENT_PORT=9101
DOCTOR_DEV_AGENT_API_KEY=replace-with-uuid
DOCTOR_DEV_AGENT_PROTOCOL=rest
DOCTOR_DEV_AGENT_DATA_DIR=/var/lib/doctor_dev/nodes/edge-node-1
DOCTOR_DEV_AGENT_CONFIG_DIR=/etc/doctor_dev/nodes/edge-node-1/generated
DOCTOR_DEV_AGENT_CERT_DIR=/etc/doctor_dev/certs
DOCTOR_DEV_AGENT_SSL_CERTFILE=
DOCTOR_DEV_AGENT_SSL_KEYFILE=
DOCTOR_DEV_ECHO_HOST=127.0.0.1
DOCTOR_DEV_ECHO_PORTS=3000,3001
