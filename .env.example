APP_NAME=DoctorDevPanel
APP_ENV=development
APP_SECRET=change-me-long-random-secret

HOST=127.0.0.1
PORT=8080
PUBLIC_HOST=127.0.0.1
PUBLIC_SCHEME=http

SESSION_COOKIE=doctor_dev_session
SESSION_TTL_SECONDS=43200
COOKIE_SECURE=0

USE_TLS=0
SSL_CERT_PATH=
SSL_KEY_PATH=

ADMIN_STORE_PATH=./data/admins.json
DOCTOR_DEV_DATA_DIR=./data
DOCTOR_DEV_NODES_PATH=./data/nodes.json
DOCTOR_DEV_CORES_PATH=./data/cores.json

# Logging
DOCTOR_DEV_LOG_DIR=./logs
DOCTOR_DEV_PANEL_LOG_FILE=./logs/panel.log
DEBUG=false
PYTHON_LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=info
