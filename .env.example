# Doctor Dev Panel environment
APP_NAME=Doctor Dev Panel
APP_ENV=production
APP_SECRET=change-me-long-random-secret

# Admin login. Use scripts/hash_password.py or the installer to generate this.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=pbkdf2_sha256$200000$replace_salt$replace_hash

# Server bind
HOST=0.0.0.0
PORT=8080
PUBLIC_HOST=127.0.0.1
PUBLIC_SCHEME=http

# Cookies
SESSION_COOKIE=doctor_dev_session
SESSION_TTL_SECONDS=43200
COOKIE_SECURE=0

# TLS direct mode: optional. Usually keep empty if you use Nginx/Caddy later.
USE_TLS=0
SSL_CERT_PATH=
SSL_KEY_PATH=

# Runtime paths for future phases
DOCTOR_DEV_CONFIG_PATH=/etc/doctor-dev/config.json
DOCTOR_DEV_LOG_DIR=/var/log/doctor-dev
