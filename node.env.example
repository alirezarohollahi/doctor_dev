DOCTOR_DEV_MODE=node

# Panel/control API authentication
API_KEY=change-me-node-api-key


NODE_HOST=0.0.0.0
API_PORT=62051
SSL_CERT_FILE=
SSL_KEY_FILE=

DOCTOR_DEV_NODE_DATA_DIR=./data/node
DOCTOR_DEV_NODE_ROUTING_CONFIG=./data/node/routing-config.json
DOCTOR_DEV_NODE_LOG_DIR=./logs/node
DOCTOR_DEV_NODE_LOG_FILE=./logs/node/node.log

# Data-plane performance and peer runtime sync
DOCTOR_DEV_FORWARD_BUFFER_SIZE=262144
DOCTOR_DEV_FORWARD_BACKLOG=4096
DOCTOR_DEV_FORWARD_CONNECT_TIMEOUT=5
DOCTOR_DEV_NODE_PEER_SYNC_INTERVAL=10
DOCTOR_DEV_NODE_PEER_SYNC_TIMEOUT=3

DEBUG=false
PYTHON_LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=info




