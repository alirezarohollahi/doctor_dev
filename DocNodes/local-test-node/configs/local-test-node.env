# Local test admin login only. Do not use these values on a public server.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
APP_SECRET=local-test-only-change-me-please

# Bind the admin/API server locally for testing.
HOST=127.0.0.1
PORT=8080

# Local test config selected by main.py / run-local-windows.ps1
DOCTOR_DEV_CONFIG_PATH=./DocNodes/local-test-node/configs/local-test-node.json
DOCTOR_DEV_RUNTIME_PATH=./DocNodes/local-test-node/configs/local-test-node.runtime.json
DOCTOR_DEV_UVICORN_LOG_LEVEL=info

START_CONFIG=./DocNodes/local-test-node/configs/local-test-node.json
START_RUNTIME=./DocNodes/local-test-node/configs/local-test-node.runtime.json
