
DOCTOR_DEV_MODE=panel
APP_NAME=DoctorDevPanel
APP_ENV=development

HOST=127.0.0.1
PORT=8080
PUBLIC_HOST=127.0.0.1
PUBLIC_SCHEME=http

# امنیت پنل
APP_SECRET=dev-secret-change-me

# دیتابیس فایل‌محور (فعلاً)
DOCTOR_DEV_DATA_DIR=./data
DOCTOR_DEV_NODES_PATH=./data/nodes.json
DOCTOR_DEV_CORES_PATH=./data/cores.json

# لاگ
DOCTOR_DEV_LOG_DIR=./logs
DEBUG=true

# مهم: ارتباط پنل-نود
DOCTOR_DEV_PANEL_NODE_SYNC=true
DOCTOR_DEV_PANEL_NODE_SYNC_INTERVAL=5
DOCTOR_DEV_PANEL_NODE_SYNC_TIMEOUT=3
DOCTOR_DEV_PANEL_NODE_SYNC_CONCURRENCY=16
DOCTOR_DEV_PANEL_NODE_CHECK_TIMEOUT=4
DOCTOR_DEV_PANEL_NODE_API_TIMEOUT=5
DOCTOR_DEV_PANEL_NODE_APPLY_TIMEOUT=8




