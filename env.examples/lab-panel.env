DOCTOR_DEV_MODE=panel
APP_NAME=DoctorDevPanelLab
APP_ENV=development

HOST=0.0.0.0
PORT=9000
PUBLIC_HOST=127.0.0.1
PUBLIC_SCHEME=http

APP_SECRET=lab-panel-secret-change-me-long-random
SESSION_COOKIE=doctor_dev_lab_session
SESSION_TTL_SECONDS=43200
COOKIE_SECURE=0

USE_TLS=0
SSL_CERT_PATH=
SSL_KEY_PATH=

DOCTOR_DEV_DATA_DIR=./data/lab/panel
ADMIN_STORE_PATH=./data/lab/panel/admins.json
DOCTOR_DEV_NODES_PATH=./data/lab/panel/nodes.json
DOCTOR_DEV_CORES_PATH=./data/lab/panel/cores.json
DOCTOR_DEV_NODE_RUNTIME_CACHE_PATH=./data/lab/panel/node-runtime-cache.json

DOCTOR_DEV_PANEL_NODE_SYNC=true
DOCTOR_DEV_PANEL_NODE_SYNC_INTERVAL=3
DOCTOR_DEV_PANEL_NODE_SYNC_TIMEOUT=3
DOCTOR_DEV_PANEL_NODE_SYNC_CONCURRENCY=4
DOCTOR_DEV_PANEL_NODE_CHECK_TIMEOUT=4
DOCTOR_DEV_PANEL_NODE_API_TIMEOUT=5
DOCTOR_DEV_PANEL_NODE_APPLY_TIMEOUT=8

DOCTOR_DEV_LOG_DIR=./logs/lab/panel
DOCTOR_DEV_PANEL_LOG_FILE=./logs/lab/panel/panel.log
DEBUG=true
PYTHON_LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=info
