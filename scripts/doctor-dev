#!/usr/bin/env bash
set -Eeuo pipefail

APP_DIR="${DOCTOR_DEV_APP_DIR:-/opt/doctor-dev-panel}"
SERVICE_NAME="${DOCTOR_DEV_SERVICE_NAME:-doctor-dev-panel}"
CONFIG_DIR="${DOCTOR_DEV_CONFIG_DIR:-/etc/doctor-dev-panel}"
ENV_FILE="${DOCTOR_DEV_ENV_FILE:-$CONFIG_DIR/panel.env}"
LEGACY_ENV_FILE="$APP_DIR/.env"
INSTALLER_URL="${DOCTOR_DEV_INSTALLER_URL:-https://github.com/alirezarohollahi/doctor_dev/raw/refs/heads/master/scripts/doctor_dev.sh}"
PYTHON_BIN="$APP_DIR/.venv/bin/python"
[[ -x "$PYTHON_BIN" ]] || PYTHON_BIN="$(command -v python3 || true)"

BOLD="\033[1m"; DIM="\033[2m"; RED="\033[31m"; GREEN="\033[32m"; YELLOW="\033[33m"; BLUE="\033[34m"; CYAN="\033[36m"; RESET="\033[0m"

cecho() { printf "%b\n" "$1"; }
editor_cmd() {
  if command -v nano >/dev/null 2>&1; then echo nano; elif command -v vim >/dev/null 2>&1; then echo vim; else echo vi; fi
}
active_env_file() {
  if [[ -f "$ENV_FILE" ]]; then echo "$ENV_FILE"; elif [[ -f "$LEGACY_ENV_FILE" ]]; then echo "$LEGACY_ENV_FILE"; else echo "$ENV_FILE"; fi
}
safe_env_get() {
  local key="$1" file="$(active_env_file)"
  [[ -n "$PYTHON_BIN" && -x "$PYTHON_BIN" && -f "$file" ]] || return 0
  "$PYTHON_BIN" - "$key" "$file" <<'PY'
import sys
key, path = sys.argv[1], sys.argv[2]
try:
    for raw in open(path, encoding='utf-8'):
        line = raw.strip()
        if not line or line.startswith('#') or '=' not in line:
            continue
        k, v = line.split('=', 1)
        if k.strip() == key:
            print(v.strip().strip('"').strip("'"))
            break
except FileNotFoundError:
    pass
PY
}

help_screen() {
  cecho "${CYAN}${BOLD}============================================================${RESET}"
  cecho "${CYAN}${BOLD}                     doctor-dev Help${RESET}"
  cecho "${CYAN}${BOLD}============================================================${RESET}"
  cecho "${BOLD}Usage:${RESET}"
  cecho "  doctor-dev [command]"
  echo
  cecho "${BOLD}Service commands:${RESET}"
  cecho "  ${GREEN}start${RESET}              - Start panel service"
  cecho "  ${GREEN}stop${RESET}               - Stop panel service"
  cecho "  ${GREEN}restart${RESET}            - Restart panel service"
  cecho "  ${GREEN}status${RESET}             - Show systemd status"
  cecho "  ${GREEN}logs${RESET}               - Follow service logs"
  cecho "  ${GREEN}health${RESET}             - Call local /health endpoint"
  cecho "  ${GREEN}service install${RESET}    - Create/enable systemd service for the panel"
  cecho "  ${GREEN}service remove${RESET}     - Stop/disable/remove systemd service"
  cecho "  ${GREEN}service enable${RESET}     - Enable panel service at boot"
  cecho "  ${GREEN}service disable${RESET}    - Disable panel service at boot"
  echo
  cecho "${BOLD}Config commands:${RESET}"
  cecho "  ${GREEN}config edit${RESET}        - Edit panel environment config"
  cecho "  ${GREEN}update${RESET}             - Download installer and run update-panel"
  echo
  cecho "${BOLD}Admin commands:${RESET}"
  cecho "  ${GREEN}admin list${RESET}         - List panel admins"
  cecho "  ${GREEN}admin add USER${RESET}     - Add admin or update password"
  cecho "  ${GREEN}admin remove USER${RESET}  - Remove admin"
  cecho "  ${GREEN}admin passwd USER${RESET}  - Change admin password"
  echo
  cecho "${BOLD}Directories:${RESET}"
  cecho "  App directory:  ${BLUE}${APP_DIR}${RESET}"
  cecho "  Config file:    ${BLUE}$(active_env_file)${RESET}"
  cecho "  Config dir:     ${BLUE}${CONFIG_DIR}${RESET}"
  cecho "  Service name:   ${BLUE}${SERVICE_NAME}${RESET}"
  cecho "${CYAN}${BOLD}============================================================${RESET}"
}

require_systemctl() {
  command -v systemctl >/dev/null 2>&1 || { cecho "${RED}systemctl not found.${RESET}"; exit 1; }
}

run_admin_cli() {
  if [[ ! -x "$PYTHON_BIN" ]]; then
    cecho "${RED}Python runtime not found. Run: doctor-dev update${RESET}"
    exit 1
  fi
  if [[ ! -d "$APP_DIR/doctor_dev_panel" ]]; then
    cecho "${RED}Project package not found at $APP_DIR. Run: doctor-dev update${RESET}"
    exit 1
  fi
  local env_file="$(active_env_file)"
  if [[ $EUID -eq 0 ]]; then
    DOCTOR_DEV_ENV="$env_file" PYTHONPATH="$APP_DIR" "$PYTHON_BIN" -m doctor_dev_panel.admin_cli "$@"
  else
    sudo env DOCTOR_DEV_ENV="$env_file" PYTHONPATH="$APP_DIR" "$PYTHON_BIN" -m doctor_dev_panel.admin_cli "$@"
  fi
}

write_service_unit() {
  require_systemctl
  local env_file="$(active_env_file)"
  [[ -d "$APP_DIR" ]] || { cecho "${RED}App directory not found: $APP_DIR${RESET}"; exit 1; }
  [[ -x "$APP_DIR/.venv/bin/python" ]] || { cecho "${RED}Virtualenv not found: $APP_DIR/.venv${RESET}"; exit 1; }
  [[ -f "$env_file" ]] || { cecho "${RED}Env file not found: $env_file${RESET}"; exit 1; }
  sudo tee "/etc/systemd/system/${SERVICE_NAME}.service" >/dev/null <<SERVICE
[Unit]
Description=Doctor Dev Panel
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$APP_DIR
Environment=DOCTOR_DEV_ENV=$env_file
Environment=PYTHONPATH=$APP_DIR
ExecStart=$APP_DIR/.venv/bin/python $APP_DIR/main.py --env $env_file
Restart=always
RestartSec=3
KillSignal=SIGTERM
TimeoutStopSec=30
User=root

[Install]
WantedBy=multi-user.target
SERVICE
  sudo systemctl daemon-reload
  sudo systemctl enable "$SERVICE_NAME" >/dev/null
  cecho "${GREEN}✓ Panel service installed/enabled: ${SERVICE_NAME}${RESET}"
}

remove_service_unit() {
  require_systemctl
  sudo systemctl stop "$SERVICE_NAME" 2>/dev/null || true
  sudo systemctl disable "$SERVICE_NAME" 2>/dev/null || true
  sudo rm -f "/etc/systemd/system/${SERVICE_NAME}.service"
  sudo systemctl daemon-reload
  cecho "${GREEN}✓ Panel service removed: ${SERVICE_NAME}${RESET}"
}

cmd="${1:-help}"
case "$cmd" in
  start)
    require_systemctl; sudo systemctl start "$SERVICE_NAME" ;;
  stop)
    require_systemctl; sudo systemctl stop "$SERVICE_NAME" ;;
  restart)
    require_systemctl; sudo systemctl restart "$SERVICE_NAME" ;;
  status)
    require_systemctl; systemctl status "$SERVICE_NAME" --no-pager ;;
  logs)
    require_systemctl; journalctl -u "$SERVICE_NAME" -f -n "${2:-120}" ;;
  service)
    sub="${2:-}"
    case "$sub" in
      install) write_service_unit ;;
      remove|uninstall) remove_service_unit ;;
      enable) require_systemctl; sudo systemctl enable "$SERVICE_NAME" ;;
      disable) require_systemctl; sudo systemctl disable "$SERVICE_NAME" ;;
      *) cecho "${YELLOW}Usage: doctor-dev service [install|remove|enable|disable]${RESET}"; exit 2 ;;
    esac
    ;;
  config)
    sub="${2:-}"
    if [[ "$sub" == "edit" ]]; then
      sudo mkdir -p "$(dirname "$(active_env_file)")"
      sudo "$(editor_cmd)" "$(active_env_file)"
    else
      cecho "${YELLOW}Usage: doctor-dev config edit${RESET}"
      exit 2
    fi
    ;;
  edit-env)
    cecho "${YELLOW}edit-env is a legacy alias. Use: doctor-dev config edit${RESET}"
    sudo mkdir -p "$(dirname "$(active_env_file)")"
    sudo "$(editor_cmd)" "$(active_env_file)"
    ;;
  admin)
    shift || true
    [[ $# -ge 1 ]] || { cecho "${YELLOW}Usage: doctor-dev admin [list|add|remove|passwd]${RESET}"; exit 2; }
    run_admin_cli "$@"
    ;;
  health)
    port="$(safe_env_get PORT)"; port="${port:-8080}"
    use_tls="$(safe_env_get USE_TLS)"; scheme="http"; curl_opts="-fsS"
    if [[ "$use_tls" == "1" ]]; then scheme="https"; curl_opts="-fkS"; fi
    curl $curl_opts "${scheme}://127.0.0.1:${port}/health" || {
      cecho "${YELLOW}Local health check failed. Is the service running on port ${port}?${RESET}"; exit 1;
    }
    echo
    ;;
  update)
    if [[ -x "$APP_DIR/scripts/doctor_dev.sh" ]]; then
      sudo bash "$APP_DIR/scripts/doctor_dev.sh" update-panel
    else
      tmp="/tmp/doctor_dev_update_$$.sh"
      cecho "${BLUE}Downloading installer...${RESET}"
      curl -fsSL "$INSTALLER_URL" -o "$tmp"
      sudo bash "$tmp" update-panel
      rm -f "$tmp"
    fi
    ;;
  help|-h|--help)
    help_screen ;;
  *)
    cecho "${RED}Unknown command: $cmd${RESET}"
    echo
    help_screen
    exit 2
    ;;
esac




